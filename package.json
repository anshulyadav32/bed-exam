{
  "name": "bed-exam-react",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config frontend/vite.config.js",
    "migrate": "npm --prefix backend run migrate",
    "start": "npm --prefix backend run start",
    "dev:api": "npm --prefix backend run dev",
    "dev:all": "npm run dev:api & npm run dev",
    "build": "vite build --config frontend/vite.config.js",
    "preview": "vite preview --config frontend/vite.config.js",
    "test:frontend": "vitest run tests/frontend",
    "test:backend": "vitest run tests/backend",
    "test": "vitest run"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.14.1"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^5.2.0",
    "jsdom": "^29.0.2",
    "prisma": "^5.22.0",
    "vite": "^5.4.10",
    "vitest": "^4.1.5"
  }
}
